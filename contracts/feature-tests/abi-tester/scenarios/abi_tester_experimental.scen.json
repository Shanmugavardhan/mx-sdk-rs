{
    "name": "abi tester full suite",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "1,000,000"
                },
                "sc:abi-tester": {
                    "nonce": "0",
                    "balance": "0",
                    "code": "mxsc:../output/abi-tester.mxsc.json"
                }
            }
        },
        {
            "step": "scQuery",
            "id": "item-for-managed-vec",
            "tx": {
                "to": "sc:abi-tester",
                "function": "item_for_managed_vec",
                "arguments": []
            },
            "expect": {
                "out": [
                    ""
                ],
                "status": "0"
            }
        },
        {
            "step": "scQuery",
            "id": "item-for-managed-complex-vec",
            "tx": {
                "to": "sc:abi-tester",
                "function": "item_for_managed_complex_vec",
                "arguments": []
