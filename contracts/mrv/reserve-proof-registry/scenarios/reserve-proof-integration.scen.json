{
    "name": "reserve proof registry integration lifecycle",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "1",
                    "balance": "1,000,000"
                },
                "address:governance": {
                    "nonce": "1",
                    "balance": "1,000,000"
                },
                "sc:carbon": {
                    "nonce": "0",
                    "balance": "0",
                    "code": "mxsc:../../carbon-credit/output/mrv-carbon-credit.mxsc.json",
                    "esdt": {
                        "str:DVCU-123456": {
                            "roles": [ "Mint", "Burn" ]
                        },
                        "str:DGSC-123456": {
                            "roles": [ "Mint", "Burn" ]
                        }
                    }
                },
                "sc:buffer": {
                    "nonce": "0",
                    "balance": "0",
                    "code": "mxsc:../../buffer-pool/output/mrv-buffer-pool.mxsc.json",
                    "esdt": {
                        "str:DVCUBUF-123456": {
                            "roles": [ "Mint", "Burn" ]
                        }
                    }
                }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "1",
                    "newAddress": "sc:gov"
                },
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "2",
                    "newAddress": "sc:reserve_proof"
                }
            ]
        },
        {
            "step": "scDeploy",
            "id": "deploy-governance",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../../governance/output/mrv-governance.mxsc.json",
                "arguments": [
                    "1",
                    "3600",
                    "address:governance"
                ],
                "gasLimit": "50,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scDeploy",
            "id": "deploy-reserve",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/mrv-reserve-proof-registry.mxsc.json",
                "arguments": [
                    "address:governance"
                ],
                "gasLimit": "50,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-carbon-tokens",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "setDvcuTokenId",
                "arguments": [ "str:DVCU-123456" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-carbon-dgsc",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "setDgscTokenId",
                "arguments": [ "str:DGSC-123456" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-carbon-gov-read",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "setGovernanceReadAddress",
                "arguments": [ "sc:gov" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-governance-verifier",
            "tx": {
                "from": "address:governance",
                "to": "sc:gov",
                "function": "proposeGsocVerifier",
                "arguments": [
                    "address:governance",
                    "str:cid",
                    "str:SG"
                ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "approve-governance-verifier",
            "tx": {
                "from": "address:governance",
                "to": "sc:gov",
                "function": "approveGsocVerifierProposal",
                "arguments": [ "1" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "setState",
            "currentBlockInfo": {
                "blockTimestamp": "4000"
            }
        },
        {
            "step": "scCall",
            "id": "execute-governance-verifier",
            "tx": {
                "from": "address:governance",
                "to": "sc:gov",
                "function": "executeGsocVerifierProposal",
                "arguments": [ "1" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-buffer-token",
            "tx": {
                "from": "address:governance",
                "to": "sc:buffer",
                "function": "setBufferTokenId",
                "arguments": [ "str:DVCUBUF-123456" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-reserve-carbon-addr",
            "tx": {
                "from": "address:governance",
                "to": "sc:reserve_proof",
                "function": "setCarbonCreditAddr",
                "arguments": [ "sc:carbon" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "setup-reserve-buffer-addr",
            "tx": {
                "from": "address:governance",
                "to": "sc:reserve_proof",
                "function": "setBufferPoolAddr",
                "arguments": [ "sc:buffer" ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "seed-ime-record",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "registerImeRecord",
                "arguments": [
                    "str:project-int-001",
                    "str:sha256:image-int-001",
                    "str:sha256:param-int-001",
                    "str:sha256:cal-int-001",
                    "str:sha256:strata-int-001",
                    "str:1.0.0",
                    "9999999999",
                    "str:KE"
                ],
                "gasLimit": "10,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "seed-committed-bundle",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "registerCommittedBundle",
                "arguments": [
                    "str:pai-int-001",
                    "1",
                    "0x2121212121212121212121212121212121212121212121212121212121212121"
                ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "seed-issue-credits",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "issueCredits",
                "arguments": [
                    "str:project-int-001",
                    "str:lot-int-001",
                    "str:pai-int-001",
                    "1",
                    "str:KE",
                    "1000",
                    "100",
                    "str:sha256:image-int-001",
                    "str:sha256:param-int-001",
                    "str:sha256:cal-int-001",
                    "str:sha256:strata-int-001",
                    "str:1.0.0",
                    "0x2121212121212121212121212121212121212121212121212121212121212121",
                    "address:owner"
                ],
                "gasLimit": "20,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "anchor-dvcu-proof",
            "tx": {
                "from": "address:governance",
                "to": "sc:reserve_proof",
                "function": "anchorReserveProof",
                "arguments": [
                    "str:DVCU-123456",
                    "990",
                    "10",
                    "0",
                    "0x1111111111111111111111111111111111111111111111111111111111111111",
                    "100"
                ],
                "gasLimit": "10,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "seed-gsoc-bundle",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "registerGsocBundle",
                "arguments": [
                    "str:pai-gsoc-int",
                    "1",
                    "0x2222222222222222222222222222222222222222222222222222222222222222"
                ],
                "gasLimit": "5,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "seed-issue-gsoc",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "issueGsocCredits",
                "arguments": [
                    "str:GSOC-KE-001",
                    "str:pai-gsoc-int",
                    "1",
                    "0x2222222222222222222222222222222222222222222222222222222222222222",
                    "address:governance",
                    "str:dna-gsoc-int",
                    "str:ITMO-GSOC-INT-001",
                    "500",
                    "100",
                    "address:governance"
                ],
                "gasLimit": "20,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "burn-retire-gsoc",
            "tx": {
                "from": "address:governance",
                "to": "sc:carbon",
                "function": "burnAndRetireGsoc",
                "arguments": [
                    "str:ITMO-GSOC-INT-001",
                    "50",
                    "str:Beneficiary",
                    "address:governance"
                ],
                "esdtValue": [
                    {
                        "tokenIdentifier": "str:DGSC-123456",
                        "value": "50"
                    }
                ],
                "gasLimit": "10,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "anchor-gsoc-proof",
            "tx": {
                "from": "address:governance",
                "to": "sc:reserve_proof",
                "function": "anchorGsocReserveProof",
                "arguments": [
                    "str:GSOC-KE-001",
                    "450",
                    "50",
                    "1",
                    "0x9b713e1f33ba9fbe64033b6e08e8da0bd13861536376115bd54d6addeb59cc23",
                    "100"
                ],
                "gasLimit": "10,000,000"
            },
            "expect": { "status": "0" }
        },
        {
            "step": "scCall",
            "id": "monotonic-block-guard-fail",
            "tx": {
                "from": "address:governance",
                "to": "sc:reserve_proof",
                "function": "anchorReserveProof",
                "arguments": [
                    "str:DVCU-123456",
                    "990",
                    "10",
                    "0",
                    "0x3333333333333333333333333333333333333333333333333333333333333333",
                    "50"
                ],
                "gasLimit": "10,000,000"
            },
            "expect": {
                "status": "4",
                "message": "str:SNAPSHOT_BLOCK_NOT_MONOTONIC: new block must be greater than current latest"
            }
        }
    ]
}
