{
    "name": "mrv aggregator init",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "1,000,000"
                },
                "address:oracle1": {
                    "nonce": "0",
                    "balance": "0"
                },
                "address:oracle2": {
                    "nonce": "0",
                    "balance": "0"
                }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "0",
                    "newAddress": "sc:mrv_aggregator"
                }
            ]
        },
        {
            "step": "scDeploy",
            "id": "deploy",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/mrv-aggregator.mxsc.json",
                "arguments": [
                    "2",
                    "172800",
                    "864000",
                    "2592000",
                    "3000"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "register-oracle1",
            "tx": {
                "from": "address:owner",
                "to": "sc:mrv_aggregator",
                "function": "registerOracle",
                "arguments": [
                    "address:oracle1"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "register-oracle2",
            "tx": {
                "from": "address:owner",
                "to": "sc:mrv_aggregator",
                "function": "registerOracle",
                "arguments": [
                    "address:oracle2"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scQuery",
            "id": "query-oracle1-authorized",
            "comment": "oracle1 was registered — isOracleAuthorized returns true",
            "tx": {
                "to": "sc:mrv_aggregator",
                "function": "isOracleAuthorized",
                "arguments": [
                    "address:oracle1"
                ]
            },
            "expect": {
                "out": [
                    "0x01"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-oracle2-authorized",
            "comment": "oracle2 was registered — isOracleAuthorized returns true",
            "tx": {
                "to": "sc:mrv_aggregator",
                "function": "isOracleAuthorized",
                "arguments": [
                    "address:oracle2"
                ]
            },
            "expect": {
                "out": [
                    "0x01"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-unregistered-oracle",
            "comment": "Unregistered address returns false (empty/zero)",
            "tx": {
                "to": "sc:mrv_aggregator",
                "function": "isOracleAuthorized",
                "arguments": [
                    "address:owner"
                ]
            },
            "expect": {
                "out": [
                    ""
                ]
            }
        }
    ]
}
