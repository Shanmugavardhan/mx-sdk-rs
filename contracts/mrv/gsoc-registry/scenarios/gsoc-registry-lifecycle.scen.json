{
    "name": "gsoc registry full lifecycle",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "1,000,000"
                },
                "address:governance": {
                    "nonce": "0",
                    "balance": "0"
                },
                "address:verifier": {
                    "nonce": "0",
                    "balance": "0"
                }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "0",
                    "newAddress": "sc:gsoc_registry"
                }
            ]
        },
        {
            "step": "scDeploy",
            "id": "deploy",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/mrv-gsoc-registry.mxsc.json",
                "arguments": [
                    "address:governance"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "reserve-serial",
            "tx": {
                "from": "address:governance",
                "to": "sc:gsoc_registry",
                "function": "reserveSerial",
                "arguments": [
                    "str:KE-DH-SOC-00001"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": [
                    "0x01"
                ],
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "register-batch",
            "tx": {
                "from": "address:governance",
                "to": "sc:gsoc_registry",
                "function": "registerSerialBatch",
                "arguments": [
                    "str:KE-DH-SOC-00001",
                    "str:PROJ-001",
                    "2026",
                    "1",
                    "1",
                    "1"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "add-verifier",
            "tx": {
                "from": "address:governance",
                "to": "sc:gsoc_registry",
                "function": "addVerifier",
                "arguments": [
                    "address:verifier"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "retire-serial",
            "tx": {
                "from": "address:verifier",
                "to": "sc:gsoc_registry",
                "function": "recordRetirement",
                "arguments": [
                    "str:KE-DH-SOC-00001",
                    "str:Acme Corp",
                    "address:owner",
                    "str:tx:0xabc123"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "double-retire-fails",
            "tx": {
                "from": "address:verifier",
                "to": "sc:gsoc_registry",
                "function": "recordRetirement",
                "arguments": [
                    "str:KE-DH-SOC-00001",
                    "str:Other Corp",
                    "address:owner",
                    "str:tx:0xdef456"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "4",
                "message": "str:SERIAL_ALREADY_RETIRED",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scQuery",
            "id": "check-retired",
            "tx": {
                "to": "sc:gsoc_registry",
                "function": "isSerialRetired",
                "arguments": [
                    "str:KE-DH-SOC-00001"
                ]
            },
            "expect": {
                "out": [
                    "0x01"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-total-supply",
            "comment": "1 batch registered with quantity=1 — total supply is 1",
            "tx": {
                "to": "sc:gsoc_registry",
                "function": "getTotalSupply",
                "arguments": []
            },
            "expect": {
                "out": [
                    "1"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-total-retired",
            "comment": "1 serial retired with quantity=1 — total retired is 1",
            "tx": {
                "to": "sc:gsoc_registry",
                "function": "getTotalRetired",
                "arguments": []
            },
            "expect": {
                "out": [
                    "1"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-project-serials",
            "comment": "PROJ-001 has 1 registered serial batch",
            "tx": {
                "to": "sc:gsoc_registry",
                "function": "getProjectSerialCount",
                "arguments": [
                    "str:PROJ-001"
                ]
            },
            "expect": {
                "out": [
                    "1"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-serial-not-reserved",
            "comment": "Reservation was consumed by registerSerialBatch — serial is no longer reserved",
            "tx": {
                "to": "sc:gsoc_registry",
                "function": "isSerialReserved",
                "arguments": [
                    "str:KE-DH-SOC-00001"
                ]
            },
            "expect": {
                "out": [
                    ""
                ]
            }
        }
    ]
}
