{
    "name": "mrv governance multisig init",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "1,000,000"
                },
                "address:signer1": {
                    "nonce": "0",
                    "balance": "0"
                },
                "address:signer2": {
                    "nonce": "0",
                    "balance": "0"
                },
                "address:target-contract": {
                    "nonce": "0",
                    "balance": "0"
                }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "0",
                    "newAddress": "sc:mrv_governance_multisig"
                }
            ]
        },
        {
            "step": "scDeploy",
            "id": "deploy",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/mrv-governance-multisig.mxsc.json",
                "arguments": [
                    "2",
                    "address:signer1",
                    "address:signer2"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "add-signer1",
            "tx": {
                "from": "address:owner",
                "to": "sc:mrv_governance_multisig",
                "function": "addSigner",
                "arguments": [
                    "address:signer1"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "add-signer2",
            "tx": {
                "from": "address:owner",
                "to": "sc:mrv_governance_multisig",
                "function": "addSigner",
                "arguments": [
                    "address:signer2"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "propose-action",
            "tx": {
                "from": "address:signer1",
                "to": "sc:mrv_governance_multisig",
                "function": "proposeAction",
                "arguments": [
                    "str:PROP-001",
                    "str:freeze",
                    "address:target-contract",
                    "str:bafybeigdyrzt5sfp7udm7hu76uh7y26nf3efuylqabf3oclgtqy55fbzdi"
                ],
                "gasLimit": "15,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scQuery",
            "id": "query-is-signer1",
            "comment": "signer1 was added — isSigner should return true",
            "tx": {
                "to": "sc:mrv_governance_multisig",
                "function": "isSigner",
                "arguments": [
                    "address:signer1"
                ]
            },
            "expect": {
                "out": [
                    "0x01"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-is-signer2",
            "comment": "signer2 was added — isSigner should return true",
            "tx": {
                "to": "sc:mrv_governance_multisig",
                "function": "isSigner",
                "arguments": [
                    "address:signer2"
                ]
            },
            "expect": {
                "out": [
                    "0x01"
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-is-signer-owner",
            "comment": "Owner is auto-added as signer in init",
            "tx": {
                "to": "sc:mrv_governance_multisig",
                "function": "isSigner",
                "arguments": [
                    "address:owner"
                ]
            },
            "expect": {
                "out": [
                    "0x01"
                ]
            }
        }
    ]
}
