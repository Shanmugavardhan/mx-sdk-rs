{
    "name": "atomic swap init",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "1,000,000"
                },
                "address:buyer": {
                    "nonce": "0",
                    "balance": "0"
                },
                "address:dealer": {
                    "nonce": "0",
                    "balance": "0"
                }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "0",
                    "newAddress": "sc:mrv_atomic_swap"
                }
            ],
            "currentBlockInfo": {
                "blockEpoch": "10"
            }
        },
        {
            "step": "scDeploy",
            "id": "deploy",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/mrv-atomic-swap.mxsc.json",
                "arguments": [
                    "str:COME-abcdef"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": [],
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "create-rfq",
            "tx": {
                "from": "address:owner",
                "to": "sc:mrv_atomic_swap",
                "function": "createRfq",
                "arguments": [
                    "str:RFQ-001",
                    "address:buyer",
                    "address:dealer",
                    "str:CARBON-a1b2c3",
                    "100",
                    "50,000",
                    "500",
                    "100"
                ],
                "gasLimit": "20,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "create-rfq-2",
            "tx": {
                "from": "address:owner",
                "to": "sc:mrv_atomic_swap",
                "function": "createRfq",
                "arguments": [
                    "str:RFQ-002",
                    "address:buyer",
                    "address:dealer",
                    "str:CARBON-a1b2c3",
                    "250",
                    "125,000",
                    "500",
                    "200"
                ],
                "gasLimit": "20,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scQuery",
            "id": "query-locked-balance-buyer-zero",
            "comment": "No margin deposited yet — locked balance for buyer should be zero",
            "tx": {
                "to": "sc:mrv_atomic_swap",
                "function": "getLockedBalance",
                "arguments": [
                    "address:buyer"
                ]
            },
            "expect": {
                "out": [
                    ""
                ]
            }
        },
        {
            "step": "scQuery",
            "id": "query-nonexistent-rfq",
            "comment": "Querying a non-existent RFQ returns OptionalValue::None (empty output)",
            "tx": {
                "to": "sc:mrv_atomic_swap",
                "function": "getRfq",
                "arguments": [
                    "str:RFQ-999"
                ]
            },
            "expect": {
                "out": []
            }
        }
    ]
}
