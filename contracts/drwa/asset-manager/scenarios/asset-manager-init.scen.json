{
    "name": "drwa asset manager holder sync",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "1,000,000"
                },
                "address:other": {
                    "nonce": "0",
                    "balance": "1,000,000"
                }
            },
            "newAddresses": [
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "0",
                    "newAddress": "sc:drwa_policy_registry"
                },
                {
                    "creatorAddress": "address:owner",
                    "creatorNonce": "1",
                    "newAddress": "sc:drwa_asset_manager"
                }
            ],
            "authorizedDRWASyncCallers": [
                "sc:drwa_policy_registry",
                "sc:drwa_asset_manager",
                "sc:drwa_identity_registry",
                "sc:drwa_attestation",
                "sc:drwa_auth_admin"
            ]
        },
        {
            "step": "scDeploy",
            "id": "deploy-policy-registry",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../../policy-registry/output/drwa-policy-registry.mxsc.json",
                "arguments": [
                    "address:owner"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scDeploy",
            "id": "deploy",
            "tx": {
                "from": "address:owner",
                "contractCode": "mxsc:../output/drwa-asset-manager.mxsc.json",
                "arguments": [
                    "address:owner"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "set-policy-registry-address",
            "tx": {
                "from": "address:owner",
                "to": "sc:drwa_asset_manager",
                "function": "setPolicyRegistryAddress",
                "arguments": [
                    "sc:drwa_policy_registry"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "set-token-policy",
            "tx": {
                "from": "address:owner",
                "to": "sc:drwa_policy_registry",
                "function": "setTokenPolicy",
                "arguments": [
                    "str:HOTEL-ab12cd",
                    "true",
                    "false",
                    "false",
                    "false",
                    "nested:str:ACCREDITED",
                    "nested:str:SG"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "register-asset",
            "tx": {
                "from": "address:owner",
                "to": "sc:drwa_asset_manager",
                "function": "registerAsset",
                "arguments": [
                    "str:HOTEL-ab12cd",
                    "str:ESDT",
                    "str:Hospitality",
                    "str:HOTEL-ab12cd"
                ],
                "gasLimit": "50,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": "*",
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "sync-holder",
            "tx": {
                "from": "address:owner",
                "to": "sc:drwa_asset_manager",
                "function": "syncHolderCompliance",
                "arguments": [
                    "str:HOTEL-ab12cd",
                    "address:investor1",
                    "str:approved",
                    "str:clear",
                    "str:accredited",
                    "str:SG",
                    "250",
                    "false",
                    "false",
                    "false"
                ],
                "gasLimit": "100,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "sync-holder-v2",
            "tx": {
                "from": "address:owner",
                "to": "sc:drwa_asset_manager",
                "function": "syncHolderCompliance",
                "arguments": [
                    "str:HOTEL-ab12cd",
                    "address:investor1",
                    "str:approved",
                    "str:clear",
                    "str:accredited",
                    "str:SG",
                    "251",
                    "true",
                    "false",
                    "false"
                ],
                "gasLimit": "100,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "0",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scQuery",
            "id": "verify-asset-registered",
            "tx": {
                "to": "sc:drwa_asset_manager",
                "function": "getAsset",
                "arguments": [
                    "str:HOTEL-ab12cd"
                ]
            },
            "expect": {
                "out": [
                    "*"
                ],
                "status": "0"
            }
        },
        {
            "step": "scCall",
            "id": "sync-holder-unauthorized",
            "tx": {
                "from": "address:other",
                "to": "sc:drwa_asset_manager",
                "function": "syncHolderCompliance",
                "arguments": [
                    "str:HOTEL-ab12cd",
                    "address:investor1",
                    "str:approved",
                    "str:clear",
                    "str:accredited",
                    "str:SG",
                    "252",
                    "false",
                    "false",
                    "false"
                ],
                "gasLimit": "100,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "status": "4",
                "message": "str:caller not authorized",
                "out": "*",
                "gas": "*",
                "refund": "*"
            }
        }
    ]
}